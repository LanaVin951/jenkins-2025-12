
Процедура ОбработкаПроведения(Отказ, Режим)
	
	// регистр Склад Расход
	Движения.ОстаткиТоваров.Записывать = Истина;
	Движения.ОстаткиТоваров.Записать();

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	&Склад КАК Склад,
		|	ПродажаТовары.Товар КАК Товар,
		|	СУММА(ПродажаТовары.Количество) КАК Количество
		|ПОМЕСТИТЬ ВТ
		|ИЗ
		|	Документ.Продажа.Товары КАК ПродажаТовары
		|ГДЕ
		|	ПродажаТовары.Ссылка = &Ссылка
		|
		|СГРУППИРОВАТЬ ПО
		|	ПродажаТовары.Товар
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ.Товар КАК Товар,
		|	ВТ.Количество КАК Количество,
		|	ЕСТЬNULL(СкладОстатки.КоличествоОстаток, 0) КАК КоличествоОстаток
		|ИЗ
		|	ВТ КАК ВТ
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТоваров.Остатки(
		|				&МоментВремени,
		|				(Склад, Товар) В
		|					(ВЫБРАТЬ
		|						ВТ.Склад,
		|						ВТ.Товар
		|					ИЗ
		|						ВТ)) КАК СкладОстатки
		|		ПО (СкладОстатки.Товар = ВТ.Товар)
		|			И (СкладОстатки.Склад = ВТ.Склад)";
	
	Запрос.УстановитьПараметр("Склад", Склад);
	Запрос.УстановитьПараметр("МоментВремени", МоментВремени());
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Если ВыборкаДетальныеЗаписи.КоличествоОстаток < ВыборкаДетальныеЗаписи.Количество  Тогда
			Сообщить(СтрШаблон("Не хватает %1 шт по номенклатуре %2: в документе %3 шт, на складе %4 шт", 
			(ВыборкаДетальныеЗаписи.Количество-ВыборкаДетальныеЗаписи.КоличествоОстаток), ВыборкаДетальныеЗаписи.Товар, ВыборкаДетальныеЗаписи.Количество, ВыборкаДетальныеЗаписи.КоличествоОстаток));
			Отказ = Истина;
		КонецЕсли;
		
		Движение = Движения.ОстаткиТоваров.Добавить();
		Движение.ВидДвижения = ВидДвиженияНакопления.Расход;
		Движение.Период = Дата;
		Движение.Товар = ВыборкаДетальныеЗаписи.Товар;
		Движение.Количество = Мин(ВыборкаДетальныеЗаписи.Количество, ВыборкаДетальныеЗаписи.КоличествоОстаток);
		
	КонецЦикла;

КонецПроцедуры
